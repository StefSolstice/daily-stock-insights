# TuShare API Token，请到 https://tushare.pro/ 注册获取
TUSHARE_TOKEN=your_tushare_token_here

# Web服务配置
FLASK_APP=web/app.py
FLASK_ENV=production
SECRET_KEY=your-secret-key-here-change-in-production

# 股票池配置（逗号分隔的股票代码）
# 例如：STOCK_POOL=000001.SZ,600519.SH,000858.SZ,601318.SH
STOCK_POOL=000001.SZ,600519.SH,000858.SZ,601318.SH

# 日志级别配置
LOG_LEVEL=INFO

# 导出目录配置
EXPORT_DIR=./exports

# 数据目录配置
DATA_DIR=./data
